RUNNER_HOST=0.0.0.0
RUNNER_PORT=4100
RUNNER_SHARED_SECRET=replace-with-at-least-32-random-bytes
RUNNER_MAX_CONCURRENCY=2
RUNNER_MAX_QUEUE_DEPTH=100
RUNNER_AUTH_MAX_SKEW_SECONDS=300
RUNNER_NONCE_TTL_SECONDS=900
RUNNER_IDEMPOTENCY_TTL_SECONDS=86400
RUNNER_TEMP_ROOT=/var/lib/learncoding-runner/tmp
RUNNER_STATE_ROOT=/var/lib/learncoding-runner

# Required: paste the five operator-built references generated by
# `npm run runtime:record` after build, inspection, contracts, and scanning.
# Blank values deliberately make startup fail; floating/example tags are unsafe.
RUNNER_IMAGE_C=
RUNNER_IMAGE_CPP=
RUNNER_IMAGE_JAVA=
RUNNER_IMAGE_PYTHON=
RUNNER_IMAGE_JAVASCRIPT=
