{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learncoding.local/schemas/roadmap-track.schema.json",
  "title": "Codestead metadata-only roadmap track",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "format",
    "schema_version",
    "id",
    "title",
    "status",
    "release",
    "prerequisites",
    "scope_brief",
    "planned_scope",
    "non_goals",
    "approval",
    "publication"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "format": { "const": "roadmap-track" },
    "schema_version": { "const": "1.0.0" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "const": "coming-soon" },
    "release": { "type": "string", "pattern": "^launch-[0-9]+$" },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "scope_brief": { "type": "string", "minLength": 20 },
    "planned_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 8 }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 8 }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "required_role", "decision_ref"],
      "properties": {
        "state": { "const": "approved-for-roadmap-only" },
        "required_role": { "const": "admin" },
        "decision_ref": { "type": "string", "minLength": 8 }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "learner_content_available",
        "authored_lessons",
        "assessment_banks",
        "exam_eligible_items",
        "requires_separate_verified_release"
      ],
      "properties": {
        "learner_content_available": { "const": false },
        "authored_lessons": { "const": 0 },
        "assessment_banks": { "const": 0 },
        "exam_eligible_items": { "const": 0 },
        "requires_separate_verified_release": { "const": true }
      }
    }
  }
}
