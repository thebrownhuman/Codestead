{
  "name": "codestead",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Codestead — build skills that stay with adaptive coding, computer science, web, DSA, and AI learning.",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "predev": "npm run sync:monaco",
    "dev": "next dev",
    "runner:local": "npm --prefix services/runner run local",
    "runner:smoke": "tsx scripts/smoke-local-runner.ts",
    "runner:power-rehearsal": "tsx scripts/runner-power-rehearsal.ts",
    "app-images:test": "node --test scripts/app-images/*.test.mjs",
    "app-images:build": "node scripts/app-images/manage-application-images.mjs build",
    "app-images:inspect": "node scripts/app-images/manage-application-images.mjs inspect",
    "app-images:sign": "node scripts/app-images/manage-application-images.mjs sign",
    "app-images:scan": "node scripts/app-images/manage-application-images.mjs scan",
    "app-images:record": "node scripts/app-images/manage-application-images.mjs record",
    "backup:credential-probe": "tsx scripts/backup/create-credential-probe.ts",
    "backup:restore-smoke": "tsx scripts/verify-restored-backup.ts",
    "prebuild": "npm run sync:monaco",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --maxWorkers=2",
    "test:auth-boundary": "vitest run --config vitest.auth-boundary.config.ts",
    "test:watch": "vitest",
    "test:integration": "tsx scripts/run-integration-tests.ts",
    "test:integration:vitest": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:browser:auth": "tsx scripts/verify-authenticated-learn-runtime.ts",
    "test:load:smoke": "tsx scripts/load-projection-smoke.ts",
    "test:load:production": "tsx scripts/load-smoke.ts",
    "production-load:ci-registration": "node infra/tests/production-load-ci-registration.test.mjs",
    "production-load:test-control:bundle": "node infra/tests/production-load-test-control-bundle.test.mjs",
    "production-load:fixture-runtime:bundle": "node infra/tests/production-load-fixture-runtime-bundle.test.mjs",
    "production-load:fixture-runtime:systemd": "node infra/tests/production-load-fixture-runtime-systemd.test.mjs",
    "production-load:fixture-runtime:lifecycle": "bash infra/tests/production-load-fixture-lifecycle.test.sh",
    "production-load:test-control:runtime": "bash infra/tests/production-load-test-control-runtime.test.sh",
    "production-load:peer-credentials": "bash infra/tests/production-load-peer-credentials.test.sh",
    "production-load:disposable-sandbox": "bash infra/tests/production-load-disposable-sandbox.test.sh",
    "production-load:release-gates": "npm run production-load:ci-registration && npm run production-load:test-control:bundle && npm run production-load:fixture-runtime:bundle && npm run production-load:fixture-runtime:systemd",
    "content:validate": "tsx scripts/validate-content.ts",
    "content:brand:check": "tsx scripts/verify-content-brand.ts",
    "curriculum:runtime-pins:apply": "tsx scripts/sync-curriculum-runtime-pins.ts --apply",
    "curriculum:runtime-pins:check": "tsx scripts/sync-curriculum-runtime-pins.ts --check",
    "content:brand:apply": "tsx scripts/verify-content-brand.ts --apply",
    "content:beginner-audit": "tsx scripts/audit-beginner-lessons.ts",
    "content:beginner-refresh": "tsx scripts/refresh-beginner-lessons.ts",
    "projects:catalog:validate": "tsx scripts/validate-module-project-catalog.ts",
    "projects:catalog:sync": "tsx scripts/sync-module-projects.ts",
    "dsa:parity:generate": "tsx scripts/generate-dsa-language-parity.ts --apply",
    "dsa:parity:check": "tsx scripts/verify-dsa-language-parity.ts --check --structure-only",
    "dsa:parity:verify": "tsx scripts/verify-dsa-language-parity.ts --check",
    "dsa:parity:structure:apply": "tsx scripts/verify-dsa-language-parity.ts --apply --structure-only",
    "dsa:parity:evidence:apply": "tsx scripts/verify-dsa-language-parity.ts --apply",
    "c-cpp:executable:apply": "tsx scripts/apply-c-cpp-executable-tranche.ts --apply",
    "c-cpp:executable:check": "tsx scripts/verify-c-cpp-executable-tranche.ts --check --structure-only",
    "c-cpp:executable:verify": "tsx scripts/verify-c-cpp-executable-tranche.ts --check",
    "c-cpp:executable:structure:apply": "tsx scripts/verify-c-cpp-executable-tranche.ts --apply --structure-only",
    "c-cpp:executable:evidence:apply": "tsx scripts/verify-c-cpp-executable-tranche.ts --apply",
    "java-python:executable:check": "tsx scripts/verify-java-python-code-tasks.ts --check --structure-only",
    "java-python:executable:verify": "tsx scripts/verify-java-python-code-tasks.ts --check",
    "java-python:executable:structure:apply": "tsx scripts/verify-java-python-code-tasks.ts --apply --structure-only",
    "java-python:executable:evidence:apply": "tsx scripts/verify-java-python-code-tasks.ts --apply",
    "ai-code:executable:check": "tsx scripts/verify-ai-code-tasks.ts --check --structure-only",
    "ai-code:executable:verify": "tsx scripts/verify-ai-code-tasks.ts --check",
    "ai-code:executable:structure:apply": "tsx scripts/verify-ai-code-tasks.ts --apply --structure-only",
    "ai-code:executable:evidence:apply": "tsx scripts/verify-ai-code-tasks.ts --apply",
    "web:executable:apply": "tsx scripts/apply-web-executable-tranche.ts --apply",
    "web:executable:check": "tsx scripts/verify-web-executable-tranche.ts --check --structure-only",
    "web:executable:verify": "tsx scripts/verify-web-executable-tranche.ts --check",
    "web:executable:structure:apply": "tsx scripts/verify-web-executable-tranche.ts --apply --structure-only",
    "web:executable:evidence:apply": "tsx scripts/verify-web-executable-tranche.ts --apply",
    "curriculum:stage": "tsx scripts/stage-curriculum.ts",
    "curriculum:gate": "tsx scripts/validate-curriculum-publication.ts",
    "ai:eval": "tsx scripts/run-ai-eval.ts",
    "audit:release": "tsx scripts/verify-release-audit.ts",
    "evidence:verify": "tsx scripts/verify-evidence-integrity.ts",
    "security:dependencies:known": "tsx scripts/verify-known-dependency-advisories.ts",
    "security:secrets": "tsx scripts/scan-secrets.ts",
    "security:encoding": "tsx scripts/scan-mojibake.ts",
    "security:api-surface": "tsx scripts/verify-api-auth-surface.ts --check",
    "security:api-surface:apply": "tsx scripts/verify-api-auth-surface.ts --apply",
    "architecture:check": "tsx scripts/verify-import-boundaries.ts --check",
    "architecture:apply": "tsx scripts/verify-import-boundaries.ts --apply",
    "worker:email": "tsx scripts/process-outbox.ts",
    "worker:regrade": "tsx scripts/process-assessment-regrades.ts",
    "worker:project-review-corrections": "tsx scripts/process-project-review-corrections.ts",
    "worker:exam-finalization": "tsx scripts/process-exam-finalizations.ts",
    "worker:practice-recovery": "tsx scripts/process-practice-runner-recoveries.ts",
    "worker:rewards": "tsx scripts/process-rewards.ts",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts",
    "db:seed": "tsx scripts/seed-platform.ts",
    "worker:scan": "tsx scripts/scan-uploads.ts",
    "storage:reconcile": "tsx scripts/reconcile-storage.ts",
    "lifecycle": "tsx scripts/data-lifecycle.ts",
    "worker:retention": "tsx scripts/data-lifecycle.ts retention --apply --confirm 2026-07-14.v4",
    "sync:monaco": "tsx scripts/sync-monaco-assets.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check": "npm run production-load:release-gates && npm run lint && npm run typecheck && npm run security:dependencies:known && npm run security:secrets && npm run security:encoding && npm run security:api-surface && npm run architecture:check && npm run ai:eval -- --check && npm run test:auth-boundary && npm run test:coverage && npm run content:brand:check && npm run content:validate && npm run projects:catalog:validate && npm run dsa:parity:check && npm run c-cpp:executable:check && npm run java-python:executable:check && npm run ai-code:executable:check && npm run web:executable:check && npm run audit:release && npm run evidence:verify && npm run build"
  },
  "dependencies": {
    "@better-auth/utils": "0.4.2",
    "@monaco-editor/react": "^4.7.0",
    "better-auth": "1.6.23",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "monaco-editor": "0.52.2",
    "nanoid": "^5.1.16",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "8.0.1",
    "recharts": "^3.9.2",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "fake-indexeddb": "6.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    },
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    }
  }
}
