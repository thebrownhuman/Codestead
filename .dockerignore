.git
.github
.next
/.next-*
node_modules
npm-debug.log*
*.log

# Generated or learner-controlled bytes never enter an application image build.
/next-env.d.ts
/public/monaco
/dist
/uploads

# Workstation-only tooling and root scratch artifacts never enter direct Docker contexts.
/.superpowers
/.codex-*

# Never send credentials or local deployment state to the build daemon.
.env
.env.*
!.env.example
**/*.pem
**/*.key
**/*.p12
**/*credentials*.json
**/secrets/*
!infra/secrets/README.md
!infra/secrets/.gitignore

backups
data
coverage
playwright-report
test-results
test-artifacts
docs
services/runner/dist
.DS_Store
Thumbs.db
