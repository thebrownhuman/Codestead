# Application
APP_URL=http://localhost:3000
SOURCE_CODE_URL=https://github.com/thebrownhuman/Codestead
APP_NAME=Codestead
NODE_ENV=development
# Local development only. Production always requires authentication even if
# this value is accidentally set to false.
AUTH_REQUIRED=true

# PostgreSQL
DATABASE_URL=postgresql://learncoding:learncoding@localhost:5432/learncoding

# Authentication (generate long random values; never commit real secrets)
BETTER_AUTH_SECRET=replace-with-at-least-32-random-bytes
# Optional independent HMAC key for privacy-preserving rate-limit identities.
# When empty, BETTER_AUTH_SECRET is used with domain separation.
RATE_LIMIT_HASH_KEY=
# Production-required independent HMAC key used only to derive short-lived
# lost-device mailbox proofs. Development/tests may fall back to the auth key.
LOST_DEVICE_PROOF_KEY=
# Trust exactly one proxy-set address header. The origin must only be reachable
# through that proxy; never trust arbitrary X-Forwarded-For input.
RATE_LIMIT_TRUSTED_IP_HEADER=cf-connecting-ip
# Optional JSON overrides for known policies; see docs/runbooks/rate-limiting.md.
RATE_LIMIT_OVERRIDES_JSON=
# Independent HMAC key for irreversible account-deletion tombstones (32+ bytes).
# Keep it outside database dumps and backup archives.
DELETION_TOMBSTONE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NAME=Codestead Administrator
BOOTSTRAP_ADMIN_PASSWORD=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application-level AES-256-GCM wrapping key, base64 encoded (32 bytes)
CREDENTIAL_MASTER_KEY=
NVIDIA_NIM_VALIDATION_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_NIM_TUTOR_MODEL=meta/llama-3.1-8b-instruct
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_ALLOWED_HOSTS=

# Runner boundary
RUNNER_BASE_URL=http://runner:4100
RUNNER_SHARED_SECRET=replace-with-a-separate-random-secret
RUNNER_MAX_CONCURRENCY=2
OBJECT_STORAGE_PATH=/data/objects
CLAMD_HOST=localhost
CLAMD_PORT=3310
CLAMD_TIMEOUT_SECONDS=120
UPLOAD_SCAN_POLL_SECONDS=10
UPLOAD_SCAN_BATCH_SIZE=10
UPLOAD_SCAN_LEASE_SECONDS=180
UPLOAD_SCAN_MAX_ATTEMPTS=8
UPLOAD_SCAN_RETRY_BASE_SECONDS=5
UPLOAD_SCAN_RETRY_MAX_SECONDS=900

# Mail adapter
MAIL_ADAPTER=console
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Per-request Gmail OAuth/send deadline; accepted range is 1000-25000 ms.
GMAIL_REQUEST_TIMEOUT_MS=10000
MAIL_FROM=Codestead <noreply@example.com>
MAIL_OUTBOX_PHASE=dual-write-v1
OUTBOX_WORKER_MODE=fenced-postgres-v1

# Optional Google Drive backup adapter
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Observability
LOG_LEVEL=info
SENTRY_DSN=

# Optional GitHub API token for higher public-repository rate limits.
# Private-repository access must use a future read-only GitHub App, never a PAT.
GITHUB_TOKEN=
