# Non-secret settings for the runner's separate KVM VM. Install as
# /etc/learncoding/runner.env with mode 0640. Bind only the private interface.
RUNNER_HOST=10.20.0.12
RUNNER_PORT=4100
RUNNER_SHARED_SECRET_FILE=/etc/learncoding/runner-shared-secret
RUNNER_MAX_CONCURRENCY=2
RUNNER_MAX_QUEUE_DEPTH=100
RUNNER_AUTH_MAX_SKEW_SECONDS=300
RUNNER_NONCE_TTL_SECONDS=900
RUNNER_IDEMPOTENCY_TTL_SECONDS=86400
RUNNER_TEMP_ROOT=/var/lib/learncoding-runner/tmp
RUNNER_STATE_ROOT=/var/lib/learncoding-runner
RUNNER_DOCKER_BINARY=/usr/bin/docker

# Every runtime must be built, scanned, tested, and pinned by immutable digest.
# Blank image references are deliberately non-runnable placeholders.
# Required: paste the five lines emitted by `npm run runtime:record` on
# the runner VM. Blank values fail closed; never substitute a floating tag.
RUNNER_IMAGE_C=
RUNNER_IMAGE_CPP=
RUNNER_IMAGE_JAVA=
RUNNER_IMAGE_PYTHON=
RUNNER_IMAGE_JAVASCRIPT=
