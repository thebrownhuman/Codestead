# Root-owned configuration for scripts/backup/*.sh. Install as
# /etc/learncoding/backup.env with mode 0600. Do not put secret values here.
REPO_ROOT=/opt/learncoding
COMPOSE_ENV_FILE=/etc/learncoding/compose.env
LEARN_DATA_ROOT=/srv/learncoding

# Dedicated mounted 2 TB local backup filesystem, initialized by
# init-backup-target.sh --full.
BACKUP_ROOT=/mnt/learncoding-backups
BACKUP_STAGE_ROOT=/var/tmp/learncoding-backup
BACKUP_LOCK_FILE=/run/lock/learncoding-backup.lock
AGE_RECIPIENT_FILE=/etc/learncoding/backup-age-recipient.txt

# Restore only: point this at an offline/removable identity for the duration of
# a supervised restore. Never keep the private identity on the backup drive.
# AGE_IDENTITY_FILE=/media/offline-key/learncoding-age-identity.txt

MAX_BACKUP_AGE_HOURS=36
FILESYSTEM_WARN_PERCENT=70
FILESYSTEM_CRITICAL_PERCENT=85
CHECKSUM_SAMPLE_COUNT=3
ALERT_HOOK=/etc/learncoding/alert-hook
MAX_OFFSITE_AGE_HOURS=6
MAX_RESTORE_DRILL_AGE_HOURS=2160
RESTORE_DRILL_SOURCE=offsite
RCLONE_OPERATION_TIMEOUT_SECONDS=120
RCLONE_OPERATION_GRACE_SECONDS=5
RCLONE_OUTPUT_LIMIT_BYTES=1048576

# Daily attested Google Drive publication and retention through rclone. The
# config is a root-owned credential file outside the repository and backup roots.
RCLONE_REMOTE=gdrive:Codestead/backups
RCLONE_CONFIG=/etc/learncoding/rclone.conf
CHECK_OFFSITE=1

# A distinct public recipient protects the separately wrapped credential/key
# recovery kit. Its private identity stays off the NUC and off backup media.
RECOVERY_KIT_RECIPIENT_FILE=/etc/learncoding/recovery-kit-recipient.txt
# Temporarily set only during a supervised kit creation/verification ceremony.
# RECOVERY_KIT_VERIFY_IDENTITY_FILE=/media/offline-key/recovery-kit-identity.txt
RECOVERY_KIT_METADATA_FILE=/etc/learncoding/recovery-kit-metadata.env

# Restore drill only: all three files are attached or created for one supervised
# run and removed from this configuration immediately afterwards. The operations
# image must be the immutable reviewed release digest, never a mutable tag.
# RECOVERY_KIT_IDENTITY_FILE=/media/offline-key/recovery-kit-identity.txt
# RESTORE_INCIDENT_RECORD=/etc/learncoding/restore-incident.env
# RESTORE_OPERATIONS_IMAGE=registry.example/codestead-operations@sha256:<64-hex-digest>
# RESTORE_DRILL_WORK_ROOT=/var/tmp

# Optional removable 32 GB emergency target, initialized separately with
# init-backup-target.sh --emergency. It receives only DB + recovery config.
# EMERGENCY_BACKUP_ROOT=/media/learncoding-emergency
