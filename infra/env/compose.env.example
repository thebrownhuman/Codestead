# Non-secret Compose interpolation values. Install as
# /etc/learncoding/compose.env with mode 0640. Never put passwords here.
APP_NAME=LearnCoding
APP_URL=https://learn.example.com
SOURCE_CODE_URL=https://github.com/your-account/learncoding
APP_IMAGE=learncoding-app
APP_IMAGE_TAG=local
DEPLOY_PLATFORM=linux/amd64
UPLOADS_ENABLED=false
COMPOSE_PROFILES=
LEARN_DATA_ROOT=/srv/learncoding
SECRETS_DIR=/etc/learncoding/secrets
CLOUDFLARE_CONFIG_FILE=/etc/learncoding/cloudflare/config.yml

# Replace both placeholders with reviewed immutable digests before startup.
POSTGRES_IMAGE=postgres:17-bookworm@sha256:REPLACE_WITH_64_HEX
CLOUDFLARED_IMAGE=cloudflare/cloudflared:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
CLAMAV_IMAGE=clamav/clamav:REVIEWED_VERSION_base@sha256:REPLACE_WITH_64_HEX

POSTGRES_DB=learncoding
POSTGRES_USER=learncoding

# Private address of the separate runner VM; never a public hostname.
RUNNER_BASE_URL=http://10.20.0.12:4100

GOOGLE_CLIENT_ID=
BOOTSTRAP_ADMIN_EMAIL=
MAIL_ADAPTER=gmail
MAIL_FROM=
OUTBOX_POLL_SECONDS=60
REGRADE_POLL_SECONDS=10
REGRADE_BATCH_SIZE=2
PRACTICE_RECOVERY_POLL_SECONDS=5
PRACTICE_RECOVERY_BATCH_SIZE=2
CLAMD_TIMEOUT_SECONDS=120
UPLOAD_SCAN_POLL_SECONDS=10
UPLOAD_SCAN_BATCH_SIZE=10
UPLOAD_SCAN_LEASE_SECONDS=180
UPLOAD_SCAN_MAX_ATTEMPTS=8
UPLOAD_SCAN_RETRY_BASE_SECONDS=5
UPLOAD_SCAN_RETRY_MAX_SECONDS=900
LOG_LEVEL=info
SENTRY_DSN=
