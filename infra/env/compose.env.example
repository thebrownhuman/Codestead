# Non-secret Compose interpolation values. Install as
# /etc/learncoding/compose.env with mode 0640. Never put passwords here.
APP_NAME=LearnCoding
APP_URL=https://learn.example.com
SOURCE_CODE_URL=https://github.com/your-account/learncoding
# Replace every image placeholder with a reviewed immutable digest before startup.
APP_RUNTIME_IMAGE=ghcr.io/thebrownhuman/codestead-runtime:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
APP_TOOLING_IMAGE=ghcr.io/thebrownhuman/codestead-tooling:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
APP_WORKER_IMAGE=ghcr.io/thebrownhuman/codestead-worker:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
APP_REGRADE_WORKER_IMAGE=ghcr.io/thebrownhuman/codestead-regrade-worker:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
APP_PROJECT_REVIEW_WORKER_IMAGE=ghcr.io/thebrownhuman/codestead-project-review-worker:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
APP_SCANNER_WORKER_IMAGE=ghcr.io/thebrownhuman/codestead-scanner-worker:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
APP_OPERATIONS_IMAGE=ghcr.io/thebrownhuman/codestead-operations:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
DEPLOY_PLATFORM=linux/amd64
UPLOADS_ENABLED=false
COMPOSE_PROFILES=
SECRETS_GID=2000
LEARN_DATA_ROOT=/srv/learncoding
SECRETS_DIR=/etc/learncoding/secrets
CLOUDFLARE_CONFIG_FILE=/etc/learncoding/cloudflare/config.yml
POSTGRES_IMAGE=postgres:17-bookworm@sha256:REPLACE_WITH_64_HEX
# Inspect the exact pinned image on Linux and copy its postgres passwd UID/GID.
POSTGRES_UID=REPLACE_WITH_INSPECTED_UID
POSTGRES_GID=REPLACE_WITH_INSPECTED_GID
CLOUDFLARED_IMAGE=cloudflare/cloudflared:REVIEWED_VERSION@sha256:REPLACE_WITH_64_HEX
CLAMAV_IMAGE=clamav/clamav:REVIEWED_VERSION_base@sha256:REPLACE_WITH_64_HEX

POSTGRES_DB=learncoding
POSTGRES_USER=learncoding

# Private address of the separate runner VM; never a public hostname.
RUNNER_BASE_URL=http://192.168.122.12:4100

GOOGLE_CLIENT_ID=
BOOTSTRAP_ADMIN_EMAIL=
MAIL_ADAPTER=gmail
MAIL_FROM=
# Per-request Gmail OAuth/send deadline; accepted range is 1000-25000 ms.
GMAIL_REQUEST_TIMEOUT_MS=10000
GMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.readonly
OUTBOX_POLL_SECONDS=60
MAIL_OUTBOX_PHASE=dual-write-v1
OUTBOX_WORKER_MODE=fenced-postgres-v1
REGRADE_POLL_SECONDS=10
REGRADE_BATCH_SIZE=2
PRACTICE_RECOVERY_POLL_SECONDS=5
PRACTICE_RECOVERY_BATCH_SIZE=2
CLAMD_TIMEOUT_SECONDS=120
UPLOAD_SCAN_POLL_SECONDS=10
UPLOAD_SCAN_BATCH_SIZE=10
UPLOAD_SCAN_LEASE_SECONDS=180
UPLOAD_SCAN_MAX_ATTEMPTS=8
UPLOAD_SCAN_RETRY_BASE_SECONDS=5
UPLOAD_SCAN_RETRY_MAX_SECONDS=900
LOG_LEVEL=info
SENTRY_DSN=
