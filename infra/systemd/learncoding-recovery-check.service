[Unit]
Description=Codestead bounded post-boot recovery verification
Documentation=/opt/learncoding/docs/runbooks/power-loss-recovery.md
After=learncoding-compose.service
Wants=learncoding-compose.service
OnFailure=learncoding-alert@%n.service

[Service]
Type=oneshot
User=root
Group=root
ExecStart=/usr/bin/bash /opt/learncoding/infra/ops/check-recovery.sh
TimeoutStartSec=16min
