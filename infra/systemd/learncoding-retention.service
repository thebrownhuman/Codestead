[Unit]
Description=Apply LearnCoding versioned data-retention policy
Documentation=/opt/learncoding/docs/runbooks/data-lifecycle.md
After=learncoding-compose.service
Requires=learncoding-compose.service
OnFailure=learncoding-alert@%n.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/learncoding
ExecStart=/usr/bin/docker compose --env-file /etc/learncoding/compose.env -f /opt/learncoding/compose.yaml --profile operations run --rm --no-deps lifecycle
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full
TimeoutStartSec=2h
