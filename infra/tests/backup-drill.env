# Non-secret configuration copied into a disposable Docker volume by the
# encrypted backup/restore drill. Never use these paths for a real deployment.
REPO_ROOT=/opt/learncoding
COMPOSE_ENV_FILE=/config/no-compose-env
LEARN_DATA_ROOT=/learn-data
BACKUP_ROOT=/backup
BACKUP_STAGE_ROOT=/stage
BACKUP_LOCK_FILE=/run/lock/learncoding-backup.lock
AGE_RECIPIENT_FILE=/config/recipient.txt
AGE_IDENTITY_FILE=/config/identity.txt
ENABLE_RCLONE_OFFSITE=0
CHECK_OFFSITE=0
MAX_BACKUP_AGE_HOURS=36
FILESYSTEM_WARN_PERCENT=98
FILESYSTEM_CRITICAL_PERCENT=99
