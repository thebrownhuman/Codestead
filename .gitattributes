* text=auto

# Ubuntu deployment and container entrypoints must not acquire CRLF endings.
*.sh text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf

# Preserve binary learner-facing and documentation assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
