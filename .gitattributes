* text=auto
.gitattributes text eol=lf

# Ubuntu deployment and container entrypoints must not acquire CRLF endings.
*.sh text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.mts text eol=lf
*.md text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.txt text eol=lf
infra/security/application-image-local-risk-acceptance.json text eol=lf
infra/runtime/production-load-network-attestation text eol=lf

# Preserve binary learner-facing and documentation assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
